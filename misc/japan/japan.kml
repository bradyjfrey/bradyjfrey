  <Document>
    <name>Japan Trip — Things to Do</name>
    <description>May 14–23, 2026. Tokyo, Kyoto, Nara, Osaka, Yokohama.</description>

    <Style id="tokyo"><IconStyle><color>ff2f41b8</color><Icon><href>https://maps.google.com/mapfiles/kml/paddle/red-circle.png</href></Icon></IconStyle></Style>
